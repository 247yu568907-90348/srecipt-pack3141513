local LogService = game:GetService("LogService")
local TextService = game:GetService("TextService")
local MAX_CHARS = 10000000
local function append(text)
output.Text ..= text .. "\n"
if #output.Text > MAX_CHARS then
output.Text = string.sub(output.Text, #output.Text - MAX_CHARS)
end
output.CursorPosition = #output.Text + 1
end
local function formatMessage(message, messageType)
if messageType == Enum.MessageType.MessageOutput then
return "" .. message
elseif messageType == Enum.MessageType.MessageWarning then
return "" .. message
elseif messageType == Enum.MessageType.MessageError then
return "" .. message
else
return "" .. message
end
end
LogService.MessageOut:Connect(function(message, messageType)
append(formatMessage(message, messageType))
end)
local oldPrint = print
local oldWarn = warn
local oldError = error
print = function(...)
local msg = table.concat({...}, " ")
append("" .. msg)
oldPrint(...)
end
warn = function(...)
local msg = table.concat({...}, " ")
append("" .. msg)
oldWarn(...)
end
error = function(...)
local msg = table.concat({...}, " ")
append("" .. msg)
